<!doctype html>
<html class="">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<script>
window.tailwind = window.tailwind || {};
window.tailwind.config = {
  darkMode: "class"
};
</script>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
<link href="https://cdn.jsdelivr.net/npm/flowbite@2.5.1/dist/flowbite.min.css" rel="stylesheet" />

<script>
if(localStorage.theme === "dark"){
document.documentElement.classList.add("dark");
}
</script>

</head>


<body class="min-h-screen bg-gray-100 dark:bg-gray-900 transition-colors duration-300">

<!-- Top bar: theme toggle + logout -->
 
<div class="flex justify-end gap-3 p-6">

<button id="theme-toggle"
class="bg-gray-200 dark:bg-gray-700 p-2 rounded-lg">

<svg id="theme-toggle-dark-icon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20">
<path d="M10 3.22l.61 1.9a1 1 0 00.95.69h2a1 1 0 01.59 1.81l-1.62 1.18a1 1 0 00-.36 1.12l.62 1.9a1 1 0 01-1.54 1.12L10 12.77l-1.65 1.17a1 1 0 01-1.54-1.12l.62-1.9a1 1 0 00-.36-1.12L5.45 7.62A1 1 0 016.04 5.8h2a1 1 0 00.95-.69L10 3.22z"/>
</svg>

<svg id="theme-toggle-light-icon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20">
<path d="M17.293 13.293A8 8 0 016.707 2.707 8.001 8.001 0 1017.293 13.293z"/>
</svg>

</button>

<form action="/user/logout" method="POST">
<button type="submit"
class="text-white bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg text-sm font-medium">
Logout
</button>
</form>

</div>


<!-- Main upload section + uploaded files list -->
<div class="flex items-start justify-center px-4 pb-8">

<div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow-md w-full max-w-3xl text-center">

<h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">
Welcome, <%= username %>
</h2>

<% if (error) { %>
<p class="text-sm text-red-600 dark:text-red-400 mb-3"><%= error %></p>
<% } %>

<% if (success) { %>
<p class="text-sm text-green-600 dark:text-green-400 mb-3"><%= success %></p>
<% } %>

<p class="text-gray-600 dark:text-gray-300 mb-6">
Upload a file using the area below.
</p>

<!-- File input ka name "file" rakha hai kyunki backend me upload.single('file') use ho raha hai -->
<form id="upload-form" action="/upload" method="POST" enctype="multipart/form-data">

<label for="dropzone-file"
class="flex flex-col items-center justify-center w-full h-40 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 dark:bg-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:hover:bg-gray-600">

<div class="flex flex-col items-center justify-center pt-5 pb-6">

<svg class="w-8 h-8 mb-3 text-gray-500 dark:text-gray-400"
fill="none" stroke="currentColor" viewBox="0 0 24 24">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
d="M7 16V8m0 0l-4 4m4-4l4 4m6 4V8m0 0l4 4m-4-4l-4 4"/>
</svg>

<p class="mb-2 text-sm text-gray-500 dark:text-gray-400">
<span class="font-semibold">Click to upload</span> or drag and drop
</p>

</div>

<input id="dropzone-file" type="file" class="hidden" name="file" required />

</label>

<p id="selected-file-name" class="mt-3 text-sm text-gray-600 dark:text-gray-300"></p>

<button id="upload-btn"
class="mt-4 w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg">
Upload
</button>

</form>

<div class="mt-8 text-left">
<h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Your Uploaded Files</h3>

<% if (!files || files.length === 0) { %>
<p class="text-sm text-gray-600 dark:text-gray-300">No files uploaded yet.</p>
<% } %>

<% if (files && files.length > 0) { %>
<div class="space-y-3">
<% files.forEach((file) => { %>
<div class="border border-gray-200 dark:border-gray-700 rounded-lg p-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
<div class="min-w-0">
<p class="text-sm font-medium text-gray-900 dark:text-white truncate"><%= file.fileName %></p>
<p class="text-xs text-gray-500 dark:text-gray-400">
<%= file.mimeType %> | <%= file.size %> bytes | <%= new Date(file.createdAt).toLocaleString("en-IN") %>
</p>
</div>
<div class="flex gap-2">
<a href="/file/<%= file._id %>/view" target="_blank"
class="text-white bg-indigo-600 hover:bg-indigo-700 px-3 py-1.5 rounded-lg text-xs font-medium">
View
</a>
<a href="/file/<%= file._id %>/download"
class="text-white bg-emerald-600 hover:bg-emerald-700 px-3 py-1.5 rounded-lg text-xs font-medium">
Download
</a>
</div>
</div>
<% }) %>
</div>
<% } %>
</div>

</div>

</div>


<script>

// Theme toggle ka simple logic: localStorage me dark/light save kar rahe hain
const toggle = document.getElementById("theme-toggle");
const darkIcon = document.getElementById("theme-toggle-dark-icon");
const lightIcon = document.getElementById("theme-toggle-light-icon");
const fileInput = document.getElementById("dropzone-file");
const uploadBtn = document.getElementById("upload-btn");
const uploadForm = document.getElementById("upload-form");
const selectedFileName = document.getElementById("selected-file-name");

function updateIcons() {
if(document.documentElement.classList.contains("dark")){
darkIcon.classList.remove("hidden");
lightIcon.classList.add("hidden");
}else{
lightIcon.classList.remove("hidden");
darkIcon.classList.add("hidden");
}
}

updateIcons();

toggle.addEventListener("click", () => {

document.documentElement.classList.toggle("dark");

if(document.documentElement.classList.contains("dark")){
localStorage.theme = "dark";
}else{
localStorage.theme = "light";
}

updateIcons();

});

// user file select kare tabhi upload allow karo, accidental repeat submit avoid hota hai
if (fileInput && uploadBtn && uploadForm && selectedFileName) {
uploadBtn.disabled = true;
uploadBtn.classList.add("opacity-60", "cursor-not-allowed");
fileInput.value = "";
selectedFileName.textContent = "No file selected";

fileInput.addEventListener("change", () => {
const hasFile = fileInput.files && fileInput.files.length > 0;
uploadBtn.disabled = !hasFile;
uploadBtn.classList.toggle("opacity-60", !hasFile);
uploadBtn.classList.toggle("cursor-not-allowed", !hasFile);
selectedFileName.textContent = hasFile ? fileInput.files[0].name : "No file selected";
});

uploadForm.addEventListener("submit", () => {
uploadBtn.disabled = true;
uploadBtn.textContent = "Uploading...";
});
}

</script>

<script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.1/dist/flowbite.min.js"></script>

</body>
</html>
